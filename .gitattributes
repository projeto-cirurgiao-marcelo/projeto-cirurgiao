# Normalizacao de fim de linha do monorepo.
# Motivo: o repo e editado tanto no Windows quanto via WSL. Sem isto, o git
# trata CRLF (working tree Windows) != LF (blob) e marca centenas de arquivos
# como "modified" sem mudanca real. Aqui forcamos LF no repositorio.

# Padrao: detecta texto automaticamente e armazena/checa como LF.
* text=auto eol=lf

# --- Scripts que SO rodam no Windows: manter CRLF ---
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# --- Binarios: nunca aplicar conversao de EOL ---
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.avif  binary
*.svg   text eol=lf
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.mp4   binary
*.mov   binary
*.webm  binary
*.mp3   binary
*.wav   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.7z    binary
*.db    binary
*.sqlite binary
*.keystore binary
*.jks   binary
*.jar   binary
*.exe   binary
*.dll   binary
*.p12   binary
*.pfx   binary
*.plist binary
*.lockb binary
