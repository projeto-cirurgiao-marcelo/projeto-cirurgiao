generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  name            String
  role            Role      @default(STUDENT)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  audioPreference AudioPref @default(AUTO)
  timezone        String    @default("America/Sao_Paulo")

  auditLogs         AuditLog[]
  chatConversations ChatConversation[]
  coursesInstructor Course[]           @relation("InstructorCourses")
  enrollments       Enrollment[]
  forumReplies      ForumReply[]
  forumReplyVotes   ForumReplyVote[]
  forumReports      ForumReport[]
  forumTopicVotes   ForumTopicVote[]
  forumTopics       ForumTopic[]
  gamificationChallenges GamificationChallenge[]
  gamificationEvents     GamificationEvent[]
  libraryConversations   LibraryConversation[]
  question_bank_items    question_bank_items[]
  quizAttempts           QuizAttempt[]
  refreshTokens          RefreshToken[]
  tokenUsageDaily        TokenUsageDaily[]
  userBadges             UserBadge[]
  user_mastery           user_mastery[]
  profile                UserProfile?
  userStreak             UserStreak?
  video_bookmarks        video_bookmarks[]
  videoLikes             VideoLike[]
  videoNotes             VideoNote[]
  progress               Progress[]
  videoSummaries         VideoSummary[]
  xpLogs                 XpLog[]

  @@index([deletedAt])
  @@map("users")
}

model UserProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  photoUrl            String?
  profession          String?
  specializations     String[]
  state               String?
  city                String?
  bio                 String?
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Course {
  id                  String       @id @default(uuid())
  title               String
  slug                String       @unique
  description         String?
  thumbnail           String?
  instructorId        String
  isPublished         Boolean      @default(false)
  price               Decimal      @default(0) @db.Decimal(10, 2)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  thumbnailVertical   String?
  thumbnailHorizontal String?
  deletedAt           DateTime?
  // Ordem manual definida via admin drag-drop em /admin/courses.
  // Listing default = ORDER BY position ASC, createdAt DESC. Cursos novos
  // pegam max(position)+1 ao serem criados.
  position            Int          @default(0)
  instructor          User         @relation("InstructorCourses", fields: [instructorId], references: [id], onDelete: Cascade)
  enrollments         Enrollment[]
  forumTopics         ForumTopic[]
  modules             Module[]
  mediaFolders        MediaFolder[] @relation("MediaFolderCourse")

  @@index([instructorId])
  @@index([slug])
  @@index([isPublished])
  @@index([deletedAt])
  @@index([position, createdAt])
  @@map("courses")
}

model Module {
  id                  String    @id @default(uuid())
  title               String
  description         String?
  order               Int
  courseId            String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  thumbnail           String?
  thumbnailVertical   String?
  thumbnailHorizontal String?
  deletedAt           DateTime?
  // Hierarquia de submódulos (1 nível só — validação em service).
  // Modulo raiz: parentModuleId = null, ordenado por (courseId, order).
  // Submódulo: parentModuleId = <id do pai>, ordenado por (parentModuleId, order).
  // Partial unique indexes scoped por contexto (raw SQL na migration).
  parentModuleId      String?
  parentModule        Module?   @relation("ModuleHierarchy", fields: [parentModuleId], references: [id], onDelete: Cascade)
  childModules        Module[]  @relation("ModuleHierarchy")
  course              Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  videos              Video[]

  @@index([courseId, order])
  @@index([courseId])
  @@index([deletedAt])
  @@index([parentModuleId, order])
  @@map("modules")
}

model Video {
  id              String            @id @default(uuid())
  title           String
  description     String?
  cloudflareId    String?           @unique
  cloudflareUrl   String?
  thumbnailUrl    String?
  duration        Int               @default(0)
  moduleId        String
  order           Int
  isPublished     Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tempFilePath    String?
  uploadError     String?
  uploadProgress  Int               @default(0)
  uploadStatus    VideoUploadStatus @default(PENDING)
  externalUrl     String?
  videoSource     String            @default("cloudflare")
  hlsUrl          String?
  deletedAt       DateTime?
  // Organização lógica em árvore custom — independente do path físico no R2.
  // Source of truth do path físico = hlsUrl (imutável). folderId é só catalogação.
  folderId        String?
  // Basename derivado do path R2 (ex: "abc123" de "videos/abc123/playlist.m3u8").
  // Chave de reconciliação com o pipeline externo. NULL = vídeo não-r2_hls.
  r2Basename      String?           @unique
  folder          MediaFolder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  forumTopics     ForumTopic[]
  quizzes         Quiz[]
  video_bookmarks video_bookmarks[]
  likes           VideoLike[]
  materials       VideoMaterial[]
  notes           VideoNote[]
  progress        Progress[]
  summaries       VideoSummary[]
  transcript      VideoTranscript?
  module          Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  // @@unique([moduleId, order]) substituido por partial unique index
  // (raw SQL na migration) WHERE deletedAt IS NULL — mesmo motivo de Module.
  @@index([moduleId, order])
  @@index([moduleId])
  @@index([cloudflareId])
  @@index([deletedAt])
  @@index([folderId])
  @@index([r2Basename])
  @@map("videos")
}

/// Árvore de organização custom para a Media Library admin.
/// Vídeos físicos vivem em R2; MediaFolder é só catalogação mutável.
/// Móvel à vontade — rename, mover subtree, reorder = update.
model MediaFolder {
  id        String        @id @default(uuid())
  name      String
  slug      String
  parentId  String?
  courseId  String?
  position  Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  parent    MediaFolder?  @relation("MediaFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  MediaFolder[] @relation("MediaFolderTree")
  course    Course?       @relation("MediaFolderCourse", fields: [courseId], references: [id], onDelete: SetNull)
  videos    Video[]

  @@unique([parentId, slug])
  @@index([parentId, position])
  @@index([courseId])
  @@map("media_folders")
}

model Enrollment {
  id           String    @id @default(uuid())
  userId       String
  courseId     String
  enrolledAt   DateTime  @default(now())
  completedAt  DateTime?
  progress     Int       @default(0)
  lastAccessAt DateTime  @default(now())
  course       Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

model Progress {
  id          String    @id @default(uuid())
  userId      String
  videoId     String
  watched     Boolean   @default(false)
  watchedAt   DateTime?
  watchTime   Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  video       Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
  @@map("video_progress")
}

model VideoLike {
  id        String   @id @default(uuid())
  videoId   String
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, userId])
  @@index([videoId])
  @@index([userId])
  @@map("video_likes")
}

model VideoNote {
  id        String   @id @default(uuid())
  videoId   String
  userId    String
  content   String
  timestamp Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId, userId])
  @@index([videoId])
  @@map("video_notes")
}

model VideoTranscript {
  id        String   @id @default(uuid())
  videoId   String   @unique
  language  String   @default("pt-BR")
  segments  Json
  fullText  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@map("video_transcripts")
}

model VideoMaterial {
  id          String       @id @default(uuid())
  videoId     String
  title       String
  description String?
  type        MaterialType @default(LINK)
  url         String
  fileSize    Int?
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  video       Video        @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@map("video_materials")
}

model ForumCategory {
  id          String       @id @default(uuid())
  name        String
  description String?
  icon        String?
  color       String?
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  topics      ForumTopic[]

  @@map("forum_categories")
}

model ForumTopic {
  id                String           @id @default(uuid())
  title             String
  content           String
  authorId          String
  categoryId        String
  courseId          String?
  videoId           String?
  isPinned          Boolean          @default(false)
  isClosed          Boolean          @default(false)
  isSolved          Boolean          @default(false)
  views             Int              @default(0)
  upvotes           Int              @default(0)
  downvotes         Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  lastActivityAt    DateTime         @default(now())
  videoTimestamp    Int?
  videoThumbnailUrl String?
  replies           ForumReply[]
  reports           ForumReport[]
  votes             ForumTopicVote[]
  author            User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category          ForumCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  course            Course?          @relation(fields: [courseId], references: [id])
  video             Video?           @relation(fields: [videoId], references: [id])

  @@index([categoryId])
  @@index([courseId])
  @@index([videoId])
  @@index([authorId])
  @@index([createdAt])
  @@index([lastActivityAt])
  @@map("forum_topics")
}

model ForumReply {
  id            String           @id @default(uuid())
  content       String
  topicId       String
  authorId      String
  parentReplyId String?
  isSolution    Boolean          @default(false)
  isEdited      Boolean          @default(false)
  upvotes       Int              @default(0)
  downvotes     Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  author        User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentReply   ForumReply?      @relation("ReplyToReply", fields: [parentReplyId], references: [id], onDelete: Cascade)
  childReplies  ForumReply[]     @relation("ReplyToReply")
  topic         ForumTopic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  votes         ForumReplyVote[]

  @@index([topicId])
  @@index([authorId])
  @@index([parentReplyId])
  @@index([createdAt])
  @@map("forum_replies")
}

model ForumTopicVote {
  id        String     @id @default(uuid())
  value     Int
  topicId   String
  userId    String
  createdAt DateTime   @default(now())
  topic     ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@map("forum_topic_votes")
}

model ForumReplyVote {
  id        String     @id @default(uuid())
  value     Int
  replyId   String
  userId    String
  createdAt DateTime   @default(now())
  reply     ForumReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([replyId, userId])
  @@map("forum_reply_votes")
}

model ForumReport {
  id          String       @id @default(uuid())
  topicId     String
  reporterId  String
  reason      ReportReason
  description String?
  status      ReportStatus @default(PENDING)
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  reporter    User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  topic       ForumTopic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, reporterId])
  @@index([topicId])
  @@index([reporterId])
  @@index([status])
  @@map("forum_reports")
}

model VideoSummary {
  id              String   @id @default(uuid())
  videoId         String
  userId          String
  content         String
  version         Int      @default(1)
  tokenCount      Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  generationCount Int      @default(1)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video           Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, userId, version])
  @@index([videoId])
  @@index([userId])
  @@map("video_summaries")
}

model Quiz {
  id           String         @id @default(uuid())
  videoId      String
  title        String
  description  String?
  difficulty   QuizDifficulty @default(MEDIUM)
  timeLimit    Int?
  passingScore Int            @default(70)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  attempts     QuizAttempt[]
  questions    QuizQuestion[]
  video        Video          @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@map("quizzes")
}

model QuizQuestion {
  id            String       @id @default(uuid())
  quizId        String
  question      String
  options       Json
  correctAnswer Int
  explanation   String?
  order         Int
  points        Int          @default(10)
  createdAt     DateTime     @default(now())
  answers       QuizAnswer[]
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, order])
  @@index([quizId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id             String       @id @default(uuid())
  quizId         String
  userId         String
  score          Int
  correctCount   Int
  totalQuestions Int
  timeSpent      Int?
  passed         Boolean      @default(false)
  completedAt    DateTime     @default(now())
  comboMax       Int          @default(0)
  specialtyId    String?
  answers        QuizAnswer[]
  quiz           Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  specialties    specialties? @relation(fields: [specialtyId], references: [id])
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
  @@index([completedAt])
  @@index([specialtyId])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id         String           @id @default(uuid())
  attemptId  String
  questionId String
  answer     Int
  isCorrect  Boolean
  timeSpent  Int?
  createdAt  DateTime         @default(now())
  confidence ConfidenceLevel?
  xpAwarded  Int?
  attempt    QuizAttempt      @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   QuizQuestion     @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("quiz_answers")
}

model ChatConversation {
  id        String        @id @default(uuid())
  userId    String
  videoId   String?
  courseId  String?
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId])
  @@index([videoId])
  @@index([courseId])
  @@index([createdAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String
  role           String
  content        String
  sources        Json?
  tokenCount     Int?
  feedback       String?
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("chat_messages")
}

model TranscriptEmbedding {
  id         String                 @id @default(uuid())
  videoId    String
  chunkIndex Int
  chunkText  String
  startTime  Float
  endTime    Float
  isIndexed  Boolean                @default(false)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  embedding  Unsupported("vector")?

  @@unique([videoId, chunkIndex])
  @@index([videoId])
  @@index([isIndexed])
  @@index([embedding], map: "transcript_embeddings_embedding_hnsw_idx")
  @@map("transcript_embeddings")
}

model KnowledgeDocument {
  id           String                   @id @default(uuid())
  title        String
  fileName     String
  gcsPath      String
  language     String                   @default("pt-BR")
  totalPages   Int                      @default(0)
  totalChunks  Int                      @default(0)
  status       DocumentProcessingStatus @default(PENDING)
  errorMessage String?
  processedAt  DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  chunks       KnowledgeChunk[]

  @@index([status])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id           String                 @id @default(uuid())
  documentId   String
  chunkIndex   Int
  content      String
  chapter      String?
  pageStart    Int?
  pageEnd      Int?
  language     String                 @default("pt-BR")
  embedding    Unsupported("vector")?
  isIndexed    Boolean                @default(false)
  createdAt    DateTime               @default(now())
  contentPt    String?
  chapterPt    String?
  isTranslated Boolean                @default(false)
  document     KnowledgeDocument      @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@index([isIndexed])
  @@index([embedding], map: "knowledge_chunks_embedding_hnsw_idx")
  @@map("knowledge_chunks")
}

model LibraryConversation {
  id        String           @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  LibraryMessage[]

  @@index([userId])
  @@index([createdAt])
  @@map("library_conversations")
}

model LibraryMessage {
  id             String              @id @default(uuid())
  conversationId String
  role           String
  content        String
  sources        Json?
  tokenCount     Int?
  feedback       String?
  createdAt      DateTime            @default(now())
  conversation   LibraryConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("library_messages")
}

model TokenUsageDaily {
  id         String   @id @default(uuid())
  userId     String
  date       String
  tokensUsed Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("token_usage_daily")
}

model XpLog {
  id                  String   @id @default(uuid())
  userId              String
  action              String
  xp                  Int
  description         String?
  referenceId         String?
  createdAt           DateTime @default(now())
  multiplierBreakdown Json?
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([userId, action, referenceId])
  @@map("xp_logs")
}

model UserBadge {
  id         String   @id @default(uuid())
  userId     String
  badgeSlug  String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeSlug])
  @@index([userId])
  @@map("user_badges")
}

model UserStreak {
  id                   String   @id @default(uuid())
  userId               String   @unique
  currentStreak        Int      @default(0)
  longestStreak        Int      @default(0)
  lastActiveDate       String?
  freezesAvailable     Int      @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  weekendFreezeEnabled Boolean  @default(true)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}

model GamificationChallenge {
  id          String                          @id @default(uuid())
  userId      String
  type        ChallengePeriod
  templateKey String
  title       String
  description String
  difficulty  GamificationChallengeDifficulty
  xpReward    Int
  icon        String
  target      Int
  expiresAt   DateTime
  completedAt DateTime?
  claimedAt   DateTime?
  createdAt   DateTime                        @default(now())
  user        User                            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type, expiresAt])
  @@index([expiresAt])
  @@map("gamification_challenges")
}

model GamificationEvent {
  id        String    @id @default(uuid())
  userId    String
  type      String
  data      Json
  seen      Boolean   @default(false)
  createdAt DateTime  @default(now())
  readAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, seen, createdAt])
  @@index([userId, createdAt])
  @@index([userId, readAt, createdAt])
  @@map("gamification_events")
}

/// Single-table audit trail for destructive and privilege-changing
/// operations. Producer is `AuditService.record()` in src/shared/audit/.
/// Kept intentionally simple — one row per event — so reads from the
/// admin panel stay cheap.
model AuditLog {
  id         String   @id @default(uuid())
  /// Who performed the action. Nullable because a few ops (cron jobs,
  /// system repairs) have no logged-in user.
  actorId    String?
  /// What the action was — 'course.soft_delete', 'user.role_changed',
  /// 'video.publish_toggled', etc. Free-form strings keep the schema
  /// flexible; callers pass from the AuditAction enum in code.
  action     String
  /// Canonical name of the affected entity table ('courses', 'videos',
  /// 'users', 'modules'). Useful for index filtering and admin views.
  entityType String
  /// The row id the action targeted.
  entityId   String
  /// Arbitrary context the producer wants to capture (previous values,
  /// reason strings, request metadata). Never put credentials here.
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model question_bank_items {
  id            String      @id
  specialtyId   String
  question      String
  options       Json
  correctAnswer Int
  explanation   String
  difficulty    Difficulty  @default(MEDIUM)
  active        Boolean     @default(true)
  createdById   String
  approvedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  users         User        @relation(fields: [createdById], references: [id])
  specialties   specialties @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@index([specialtyId, active])
}

model specialties {
  id                  String                @id
  slug                String                @unique
  name                String
  description         String?
  icon                String?
  displayOrder        Int                   @default(0)
  active              Boolean               @default(true)
  difficulty          Difficulty            @default(MEDIUM)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  question_bank_items question_bank_items[]
  quiz_attempts       QuizAttempt[]
  user_mastery        user_mastery[]
}

model user_mastery {
  id            String      @id
  userId        String
  specialtyId   String
  score         Float       @default(0)
  totalAttempts Int         @default(0)
  totalCorrect  Int         @default(0)
  lastReviewAt  DateTime?
  lastDecayAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  specialties   specialties @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  users         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, specialtyId])
  @@index([specialtyId])
  @@index([userId])
}

model video_bookmarks {
  id           String   @id
  videoId      String
  userId       String
  timestamp    Int
  label        String?
  thumbnailUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  users        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([userId, videoId])
  @@index([videoId])
}

model xp_rules {
  id             String   @id
  key            String   @unique
  description    String
  baseXp         Int      @default(0)
  multiplierJson Json
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
}

