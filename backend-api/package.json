{
  "name": "projeto-cirurgiao-backend",
  "version": "1.0.0",
  "description": "Backend API para o Projeto Cirurgião - Sistema de autenticação e gestão de usuários",
  "author": "Rafael - Backend Developer Sênior",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed:forum": "ts-node prisma/seed-forum.ts",
    "seed:staging": "ts-node prisma/seed-staging.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.968.0",
    "@aws-sdk/s3-request-presigner": "^3.935.0",
    "@google-cloud/secret-manager": "^6.1.1",
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.7.1",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.74.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "firebase-admin": "^13.2.0",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-parse": "^1.1.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "tus-js-client": "^4.3.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.6",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.38",
    "@types/pdf-parse": "^1.1.5",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "prettier": "^3.1.1",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "modules/**/*.service.ts",
      "shared/**/*.service.ts",
      "shared/queue/queue.config.ts",
      "shared/audit/audit.constants.ts",
      "modules/videos/dto/create-video-from-r2-hls.dto.ts",
      "!**/*.spec.ts",
      "!**/node_modules/**"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "./src/modules/courses/courses.service.ts": {
        "statements": 85,
        "branches": 70,
        "functions": 80,
        "lines": 85
      },
      "./src/modules/captions/captions.service.ts": {
        "statements": 70,
        "branches": 70,
        "functions": 80,
        "lines": 70
      },
      "./src/modules/modules/modules.service.ts": {
        "statements": 70,
        "branches": 60,
        "functions": 80,
        "lines": 70
      },
      "./src/modules/videos/videos.service.ts": {
        "statements": 50,
        "branches": 55,
        "functions": 55,
        "lines": 50
      },
      "./src/modules/users/users.service.ts": {
        "statements": 45,
        "branches": 35,
        "functions": 45,
        "lines": 45
      },
      "./src/modules/ai-summaries/ai-summaries.service.ts": {
        "statements": 60,
        "branches": 40,
        "functions": 60,
        "lines": 60
      },
      "./src/modules/quizzes/quizzes.service.ts": {
        "statements": 75,
        "branches": 65,
        "functions": 80,
        "lines": 75
      },
      "./src/shared/queue/queue.service.ts": {
        "statements": 85,
        "branches": 50,
        "functions": 85,
        "lines": 85
      },
      "./src/shared/audit/audit.service.ts": {
        "statements": 100,
        "branches": 100,
        "functions": 100,
        "lines": 100
      }
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
