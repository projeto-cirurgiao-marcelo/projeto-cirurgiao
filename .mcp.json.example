{
  "mcpServers": {
    "stitch": {
      "type": "http",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "<YOUR_GOOGLE_STITCH_API_KEY>"
      }
    },
    "magic": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "<YOUR_21ST_MAGIC_API_KEY>"
      }
    }
  }
}
