# ============================================
# PRISMA
# ============================================
# Migrations ARE tracked — they are the source of truth for DB schema.
# (Historical note: they were previously ignored, which caused drift
# between local filesystems and _prisma_migrations in prod. See
# docs/DEPLOY.md "Database migration policy".)

# ============================================
# TERRAFORM
# ============================================
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# ============================================
# DOCKER
# ============================================
docker-compose.override.yml
# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*.local
*.env

# Build outputs
dist/
build/
.next/
out/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log

# Database
*.sqlite
*.db

# Temporary files
tmp/
temp/
*.tmp

# iOS
ios-app/.build/
ios-app/DerivedData/
*.xcuserstate
*.xcworkspace/xcuserdata/

# Android
android-app/.gradle/
android-app/build/
android-app/local.properties
android-app/.idea/
android-app/*.iml

# Sensitive data
gcp-service-account-key/
*.pem
*.key
credentials/
**/CREDENCIAIS_*.md
**/credentials*.json
**/service-account*.json

# Claude Code temp files
tmpclaude-*

# --- Cleanup additions 2026-04-15 (chore/repo-cleanup) ---

# Local knowledge / progress docs (moved out of root)
Knowledge/

# VSCode local history extension
.history/

# Claude agent skills cache / local agents folder
.agents/

# Dev-only admin scripts (stays on disk, not in repo). Use file globs, not
# a bare `scripts/` rule, because bare dir ignores cannot be overridden
# (`!scripts/init-db.sql` would never re-include the file).
scripts/*
!scripts/init-db.sql
backend-api/scripts/*.js
backend-api/start-proxy.bat
mobile-app/fix_and_run.bat
mobile-app/run_android_fixed.bat

# Windows accidental artifacts
nul
-p/

# Backup archives (negate legit ones if needed)
*.zip
!infrastructure/**/*.zip
!**/templates/**/*.zip

# --- URGENT secret/size additions 2026-04-15 ---

# Cloud Run env file contains production secrets (DATABASE_URL, JWT, API tokens)
backend-api/cloud-run-env.yaml
**/cloud-run-env*.yaml
**/cloud-run-env*.yml

# Dev/admin scripts at backend-api root (not inside scripts/)
backend-api/check-*.js
backend-api/scripts/*.ts
!backend-api/scripts/set-hls-urls.ts
!backend-api/scripts/backfill-embeddings.ts

# Large data exports (GitHub file limit 100MB)
*.csv
!**/fixtures/**/*.csv
!**/test-data/**/*.csv

# Claude Code plugin cache and personal settings (local only)
.claude/skills/
.claude/skills-lock.json
.claude/settings.local.json
**/.claude/skills/
**/.claude/skills-lock.json
**/.claude/settings.local.json
skills-lock.json

# Superpowers plans and specs (local workflow docs, not shipped)
docs/superpowers/plans/
docs/superpowers/specs/
